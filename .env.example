# OpenRouteService API key (https://openrouteservice.org)
# Free tier: 2000 req/day, 40 req/min
VITE_ORS_KEY=your_ors_api_key_here

# MapTiler Cloud API key (https://cloud.maptiler.com)
# Free tier: 100,000 tiles/month
# If not set, falls back to OpenFreeMap (no Korean labels)
VITE_MAP_KEY=your_maptiler_api_key_here

# Kakao REST API key (https://developers.kakao.com)
# 앱 설정 → 앱 키 → REST API 키
# Free tier: 300,000 req/day
# 보안: 앱 설정 → 플랫폼 → Web → 사이트 도메인에 https://htjworld.github.io 등록
VITE_KAKAO_KEY=your_kakao_rest_api_key_here
